# ── LiveSubs Offline — Configuration ─────────────────────────────────────────
# Copy this file to .env and edit as needed.
# Changes here automatically apply to both Docker and the React app.
# After changing, restart Docker: docker compose up -d --force-recreate

# ── Whisper ───────────────────────────────────────────────────────────────────
WHISPER_PORT=8080
WHISPER_MODEL=Systran/faster-whisper-small

# ── LibreTranslate ────────────────────────────────────────────────────────────
LIBRETRANSLATE_PORT=5050
LT_LANGUAGES=en,es,fr,de,it,pt,ja,ko,zh,ru,ar,hi,bn

# ── Vite exposes vars prefixed with VITE_ to the browser ─────────────────────
VITE_WHISPER_URL=http://localhost:8080/v1/audio/transcriptions
VITE_TRANSLATE_URL=http://localhost:5050/translate
